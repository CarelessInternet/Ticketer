{
	"compilerOptions": {
		"types": ["bun"],
		"lib": ["ESNext"],
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"verbatimModuleSyntax": true,
		"noUncheckedIndexedAccess": true
	}
}
