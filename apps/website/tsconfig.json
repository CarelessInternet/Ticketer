{
	"extends": ["@ticketer/tsconfig/tsconfig.base.json"],
	"compilerOptions": {
		"lib": ["ESNext", "DOM"],
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./src/*"]
		},
		"allowArbitraryExtensions": true
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "**/*.mjs", ".next/types/**/*.ts", ".next/dev/types/**/*.ts"],
	"exclude": ["node_modules"]
}
